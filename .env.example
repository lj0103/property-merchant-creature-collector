PORT=8787
CLIENT_ORIGIN=http://localhost:5173
VITE_SOCKET_URL=http://localhost:8787

# 不设置 DATABASE_URL 时，服务端自动使用 JSON 文件持久化。
# 设置后默认使用 Prisma + PostgreSQL。
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/property_merchant?schema=public

# 如需在已有 DATABASE_URL 的环境里临时退回 JSON 存储，可设置：
# STORAGE_DRIVER=json

# 配置后启用 Socket.IO 跨实例广播、Redis 在线状态和分布式房间锁。
# 未设置或 Redis 不可用时自动退回单进程内存协调。
REDIS_URL=redis://localhost:6379
REDIS_LOCK_TTL_MS=5000
REDIS_PRESENCE_TTL_SECONDS=120

# 游客身份 Cookie。生产环境 NODE_ENV=production 时自动启用 Secure。
SESSION_COOKIE_NAME=pm_session
SESSION_COOKIE_MAX_AGE_MS=2592000000
# 本地 HTTP 开发保持 false；正式 HTTPS 部署设为 true。
COOKIE_SECURE=false

RECONNECT_GRACE_MS=60000
ROOM_DATA_FILE=server/data/rooms.json
